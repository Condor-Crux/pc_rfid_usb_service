# ── Configuracion del Puente USB RFID ──────────────────────────
# Copia este archivo como config.env y ajusta los valores
# ───────────────────────────────────────────────────────────────

# URL de la API web (RPi)
RFID_API_URL=http://192.168.1.100:8000

# Puerto serial del lector USB
RFID_COM=COM4

# Baud rate del lector USB
RFID_BAUD=9600

# Credenciales de administrador de la app web
RFID_API_USER=admin
RFID_API_PASS=tu_contraseña_aqui

# Intervalo de sondeo (segundos entre ciclos de lectura)
RFID_POLL_INTERVAL=0.1

# Demora antes de reconectar serial/API tras un error
RFID_RECONNECT_DELAY=5

# ID de usuario por defecto para --save-to-user (opcional)
# RFID_DEFAULT_USER_ID=9

# Valores por defecto para guardado directo de tarjetas
RFID_DEFAULT_CREDITS=1
RFID_DEFAULT_EXPIRY_DAYS=1
